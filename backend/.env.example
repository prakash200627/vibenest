# App Config
PROJECT_NAME=VibeNest API
DEBUG=true
PORT=8000
LOG_LEVEL=INFO

# Database
# For SQLite: sqlite:///instance/chat.db
# For PostgreSQL: postgresql://username:password@localhost:5432/db_name
DATABASE_URL=sqlite:///instance/chat.db

# Security
SECRET_KEY=dev-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
